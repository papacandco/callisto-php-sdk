{
  "name": "callisto/sdk",
  "description": "Official Callisto messaging API SDK for PHP",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": { "Callisto\\Sdk\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Callisto\\Sdk\\Tests\\": "tests/" }
  },
  "scripts": {
    "test": "phpunit"
  }
}
